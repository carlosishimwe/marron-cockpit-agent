# Secrets a definir dans Netlify (Site settings > Environment variables).
# Ne jamais committer ce fichier rempli, ni mettre ces valeurs dans le code.

# Token d'une connexion Notion interne (https://www.notion.so/my-integrations)
# Le nouveau format commence par ntn_
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cle OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modele gratuit par defaut. Liste : https://openrouter.ai/models?max_price=0
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optionnel, les ID des bases sont deja codes en dur dans agent.mjs.
# PROJETS_DB_ID=9642cf381ff243829efada20f671758c
# TACHES_DB_ID=f430d874e56845fc850450088740b2ee